// 数组测试
var arr = [1, 2, 3, 4, 5]
pln("初始数组: ", arr)

var sum = 0
for (var i = 0; i < 5; i = i + 1) {
    sum = sum + arr[i]
}

pln("数组元素和 = ", sum)
if (sum == 15) {
    pln("✓ 数组遍历和求和测试通过")
} else {
    pln("✗ 数组测试失败: 预期和15，实际", sum)
}

// 测试数组修改
arr[2] = 10
pln("修改后数组: ", arr)
if (arr[2] == 10) {
    pln("✓ 数组元素修改测试通过")
} else {
    pln("✗ 数组修改测试失败: 预期arr[2]=10，实际", arr[2])
}
