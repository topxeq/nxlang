// 测试位运算复合赋值
var a = 12 // 0b1100
pln("初始 a = ", a, " (二进制 1100)")

a &= 10 // 12 & 10 = 8 (0b1000)
pln("a &= 10 → ", a)
if (a == 8) { pln("✓ &= 工作正常") }

a |= 3 // 8 | 3 = 11 (0b1011)
pln("a |= 3 → ", a)
if (a == 11) { pln("✓ |= 工作正常") }

a ^= 12 // 11 ^ 12 = 7 (0b0111)
pln("a ^= 12 → ", a)
if (a == 7) { pln("✓ ^= 工作正常") }

a <<= 2 // 7 << 2 = 28 (0b11100)
pln("a <<= 2 → ", a)
if (a == 28) { pln("✓ <<= 工作正常") }

a >>= 1 // 28 >> 1 = 14 (0b1110)
pln("a >>= 1 → ", a)
if (a == 14) { pln("✓ >>= 工作正常") }

// 测试基础位运算
var b = 12 & 10
pln("\n12 & 10 = ", b)
if (b == 8) { pln("✓ & 运算正常") }

var c = 12 | 10
pln("12 | 10 = ", c)
if (c == 14) { pln("✓ | 运算正常") }

var d = 12 ^ 10
pln("12 ^ 10 = ", d)
if (d == 6) { pln("✓ ^ 运算正常") }

var e = 12 << 2
pln("12 << 2 = ", e)
if (e == 48) { pln("✓ << 运算正常") }

var f = 12 >> 2
pln("12 >> 2 = ", f)
if (f == 3) { pln("✓ >> 运算正常") }
