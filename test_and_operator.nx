// 测试逻辑与运算符
pln("true && false = ", true && false)
pln("false && true = ", false && true)
pln("false && false = ", false && false)
pln("true && true = ", true && true)

// 测试短路特性
var a = 1
var b = 2
var c = true && (a = 100)
pln("a = ", a, ", c = ", c)

var d = false && (b = 200)
pln("b = ", b, ", d = ", d)
