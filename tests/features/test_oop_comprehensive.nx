// Comprehensive OOP Test Suite for Nxlang
// Tests: classes, inheritance, super, getters/setters, dynamic methods

pln("=== Nxlang OOP Comprehensive Test Suite ===")

// ============================================
// Test 1: Basic Class Definition and Instantiation
// ============================================
pln("\n--- Test 1: Basic Class ---")

class Person {
    func init(name, age) {
        this.name = name
        this.age = age
    }

    func greet() {
        return "Hello, I'm " + this.name
    }

    func getAge() {
        return this.age
    }
}

var p1 = new Person("Alice", 25)
pln("Created person:", p1)
pln("Person name:", p1.name)
pln("Person age:", p1.getAge())
pln("Greeting:", p1.greet())

// ============================================
// Test 2: Inheritance with super()
// ============================================
pln("\n--- Test 2: Inheritance ---")

class Employee : Person {
    func init(name, age, department) {
        super.init(name, age)
        this.department = department
    }

    func getDepartment() {
        return this.department
    }

    // Override parent method
    func greet() {
        return super.greet() + " from " + this.department
    }
}

var emp1 = new Employee("Bob", 30, "Engineering")
pln("Created employee:", emp1)
pln("Employee name:", emp1.name)
pln("Employee department:", emp1.getDepartment())
pln("Employee greeting:", emp1.greet())

// ============================================
// Test 3: Method Override
// ============================================
pln("\n--- Test 3: Method Override ---")

class Manager : Employee {
    func init(name, age, department, teamSize) {
        // Note: super.init expects 3 params for Employee
        // For 3-level inheritance, super.init calls parent's init
        super.init(name, age, department)
        this.teamSize = teamSize
    }

    func getTeamSize() {
        return this.teamSize
    }
}

// Note: 3-level inheritance with super.init has known limitations
// Using 2-level inheritance for reliable testing
var mgr1 = new Manager("Carol", 40, "Sales", 15)
pln("Created manager:", mgr1)
pln("Manager department:", mgr1.getDepartment())
pln("Manager team size:", mgr1.getTeamSize())

// ============================================
// Test 4: Getter/Setter
// ============================================
pln("\n--- Test 4: Getters/Setters ---")

class Rectangle {
    func init(width, height) {
        this._width = width
        this._height = height
    }

    func getWidth() { return this._width }
    func setWidth(w) { this._width = w }
    func getHeight() { return this._height }
    func setHeight(h) { this._height = h }

    func getArea() {
        return this._width * this._height
    }
}

var rect = new Rectangle(10, 5)
pln("Rectangle area:", rect.getArea())
rect.setWidth(20)
pln("Rectangle area after width change:", rect.getArea())

// ============================================
// Test 5: Dynamic Method Addition (addMethod)
// ============================================
pln("\n--- Test 5: Dynamic Methods ---")

class Animal {
    func speak() {
        return "..."
    }
}

var dog = new Animal()
pln("Animal speaks:", dog.speak())

// Add new method dynamically
func bark() {
    return "Woof! Woof!"
}

addMethod("Animal", "bark", bark)
pln("After addMethod - Dog barks:", dog.bark())

// New instance also has the method
var cat = new Animal()
pln("New instance can bark:", cat.bark())

// ============================================
// Test 6: Dynamic Member Addition (addMember)
// ============================================
pln("\n--- Test 6: Dynamic Members ---")

class Product {
    func init(name, price) {
        this.name = name
        this.price = price
    }
}

addMember("Product", "taxRate", 0.1)
pln("addMember succeeded")

// ============================================
// Test 7: Method Chaining Pattern
// ============================================
pln("\n--- Test 7: Method Chaining ---")

class Builder {
    func init() {
        this.data = []
    }

    func add(item) {
        append(this.data, item)
        return this
    }

    func clear() {
        this.data = []
        return this
    }

    func getData() {
        return this.data
    }
}

var builder = new Builder()
builder.add(1).add(2).add(3)
pln("Builder data:", builder.getData())

// ============================================
// Test 8: this in Different Contexts
// ============================================
pln("\n--- Test 8: this context ---")

class SelfRef {
    func init(value) {
        this.value = value
    }

    func same() {
        return this
    }

    func getValue() {
        return this.value
    }
}

var sr = new SelfRef(42)
pln("SelfRef value:", sr.same().getValue())

// ============================================
// Summary
// ============================================
pln("\n=== All OOP Tests Completed Successfully ===")
