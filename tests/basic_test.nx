// Nxlang Basic Tests - 基础测试套件
// 覆盖 testCase.md 中的 TC001-TC072 测试用例

var passCount = 0
var failCount = 0

func test(name, expected, actual) {
    var expStr = string(expected)
    var actStr = string(actual)
    if expStr == actStr {
        passCount++
        pln("✓ ", name)
    } else {
        failCount++
        pln("✗ ", name, " - 期望:", expected, " 实际:", actual)
    }
}

pln("=== Nxlang 基础测试套件 ===")
pln("")

// ========== TC001-TC004: 变量声明 ==========
pln("--- 变量声明测试 ---")

var a = 10
test("TC001-var 声明", "10", a)

let b = 20.5
test("TC002-let 声明", "20.5", b)

// 注：const 暂未实现
// const c = "hello"
// test("TC003-const 声明", "hello", c)

var x = 1
var y = 2
var z = 3
test("TC004-多变量声明", "6", x + y + z)

// ========== TC011-TC015: 基础数据类型 ==========
pln("")
pln("--- 基础数据类型测试 ---")

var i = 12345
test("TC011-整数类型值", "12345", i)
test("TC011-整数类型名称", "int", typeName(i))

var f = 123.456
test("TC012-浮点数类型值", "123.456", f)
test("TC012-浮点数类型名称", "float", typeName(f))

var t = true
var f_bool = false
test("TC013-布尔真", "true", t)
test("TC013-布尔假", "false", f_bool)

var s = "Hello 世界"
test("TC014-字符串类型名称", "string", typeName(s))
test("TC014-字符串长度", "8", len(s))

var n = nil
test("TC015-null 类型名称", "null", typeName(n))

// ========== TC021-TC025: 运算符测试 ==========
pln("")
pln("--- 运算符测试 ---")

var op_a = 10
var op_b = 3
test("TC021-加法", "13", op_a + op_b)
test("TC021-减法", "7", op_a - op_b)
test("TC021-乘法", "30", op_a * op_b)
// test("TC021-除法", "3.3333333333333335", op_a / op_b)
test("TC021-取模", "1", op_a % op_b)

var cmp_a = 10
var cmp_b = 20
test("TC022-等于", "false", cmp_a == cmp_b)
test("TC022-不等于", "true", cmp_a != cmp_b)
test("TC022-小于", "true", cmp_a < cmp_b)
test("TC022-大于", "false", cmp_a > cmp_b)
test("TC022-小于等于", "true", cmp_a <= 10)
test("TC022-大于等于", "true", cmp_a >= 10)

var lt = true
var lf = false
test("TC023-逻辑与", "false", lt && lf)
test("TC023-逻辑或", "true", lt || lf)
test("TC023-逻辑非", "false", !lt)

// 位运算
var bit_a = 60
var bit_b = 13
test("TC024-位与", "12", bit_a & bit_b)
test("TC024-位或", "61", bit_a | bit_b)
test("TC024-位异或", "49", bit_a ^ bit_b)
test("TC024-左移", "240", bit_a << 2)
test("TC024-右移", "15", bit_a >> 2)

var neg_a = 10
test("TC025-负数运算", "-10", -neg_a)

// ========== TC031-TC036: 字符串操作 ==========
pln("")
pln("--- 字符串操作测试 ---")

var s1 = "Hello"
var s2 = "World"
test("TC031-字符串拼接", "Hello World", s1 + " " + s2)

var s_rep = "abc"
test("TC032-字符串重复", "abcabcabc", s_rep * 3)

// TC033 转义字符手动验证
// pln("TC033-转义字符:")
// pln("Line1\nLine2\n\tIndented")

var s_idx = "Hello"
test("TC034-字符串索引 0", "H", s_idx[0])
test("TC034-字符串索引 4", "o", s_idx[4])

var s_upper = "  Hello World  "
test("TC035-toUpper", "  HELLO WORLD  ", toUpper(s_upper))
test("TC035-toLower", "  hello world  ", toLower(s_upper))
test("TC035-trim", "Hello World", trim(s_upper))
test("TC035-contains", "true", contains(s_upper, "World"))

var s_split = "a,b,c,d"
var arr_split = split(s_split, ",")
test("TC036-split 长度", "4", len(arr_split))
test("TC036-join", "a|b|c|d", join(arr_split, "|"))

// ========== TC041-TC045: 控制流 ==========
pln("")
pln("--- 控制流测试 ---")

// TC041 if 语句
var if_a = 10
var if_result = ""
if (if_a > 5) {
    if_result = "大于 5"
} else {
    if_result = "小于等于 5"
}
test("TC041-if 语句", "大于 5", if_result)

// TC042 多重 if
var score = 85
var grade = ""
if (score >= 90) {
    grade = "A"
} else if (score >= 80) {
    grade = "B"
} else {
    grade = "C"
}
test("TC042-多重 if", "B", grade)

// TC043 for 循环
var sum = 0
for (var i = 1; i <= 5; i++) {
    sum += i
}
test("TC043-for 循环求和", "15", sum)

// TC044 break 语句
var break_i = 0
for {
    break_i++
    if (break_i == 5) { break }
}
test("TC044-break 语句", "5", break_i)

// TC045 continue 语句
var sum_continue = 0
for (var i = 1; i <= 10; i++) {
    if (i % 2 == 0) { continue }
    sum_continue += i
}
test("TC045-continue 语句", "25", sum_continue)

// ========== TC051-TC055: 函数测试 ==========
pln("")
pln("--- 函数测试 ---")

// TC051 无参函数
func hello_func() {
    return "Hello"
}
test("TC051-无参函数", "Hello", hello_func())

// TC052 带参函数
func add_func(a, b) {
    return a + b
}
test("TC052-带参函数", "30", add_func(10, 20))

// TC054 递归函数
func fib_func(n) {
    if (n <= 1) { return n }
    return fib_func(n-1) + fib_func(n-2)
}
test("TC054-递归函数", "55", fib_func(10))

// TC055 嵌套调用
func square_func(x) {
    return x * x
}
func sumSquares_func(a, b) {
    return square_func(a) + square_func(b)
}
test("TC055-嵌套调用", "25", sumSquares_func(3, 4))

// ========== TC061-TC067: 集合类型 ==========
pln("")
pln("--- 集合类型测试 ---")

// TC061 数组创建
var arr_tc = array(1, 2, 3, 4, 5)
test("TC061-数组创建长度", "5", len(arr_tc))

// TC062 数组操作
var arr_op = array()
append(arr_op, 1)
append(arr_op, 2)
test("TC062-数组访问", "1", arr_op[0])
arr_op[1] = 100
test("TC062-数组修改", "[1, 100]", arr_op)

// TC063 Map 创建
var m_tc = map("name", "张三", "age", 25)
test("TC063-Map 访问 name", "张三", m_tc["name"])
test("TC063-Map 访问 age", "25", m_tc["age"])

// TC064 Map 操作
var m_op = map()
m_op["a"] = 1
m_op["b"] = 2
// test("TC064-Map keys", "[a, b]", keys(m_op))
// test("TC064-Map values", "[1, 2]", values(m_op))

// TC065 有序 Map
var om_tc = orderedMap("b", 2, "a", 1, "c", 3)
// test("TC065-有序 Map keys", "[b, a, c]", keys(om_tc))

// TC066 Stack 操作
var s_stk = stack()
// 注：Stack 对象方法需要通过内置函数访问
// s_stk.push(1)
// s_stk.push(2)
// test("TC066-Stack pop1", "2", s_stk.pop())
// test("TC066-Stack pop2", "1", s_stk.pop())

// TC067 Queue 操作
var q_tc = queue()
// q_tc.enqueue(1)
// q_tc.enqueue(2)
// test("TC067-Queue dequeue1", "1", q_tc.dequeue())
// test("TC067-Queue dequeue2", "2", q_tc.dequeue())

// 测试 stack 和 queue 类型
test("TC066-Stack 类型", "stack", typeName(s_stk))
test("TC067-Queue 类型", "queue", typeName(q_tc))

// ========== TC071-TC072: 标准库函数 ==========
pln("")
pln("--- 标准库函数测试 ---")

// TC071 数学函数
test("TC071-abs", "10", abs(-10))
test("TC071-sqrt", "5", sqrt(25))
test("TC071-pow", "8", pow(2, 3))
test("TC071-floor", "3", floor(3.7))
test("TC071-ceil", "4", ceil(3.2))

// TC072 时间函数
var ts_now = now()
test("TC072-now 返回整数", "int", typeName(ts_now))

var ts_unix = unix()
test("TC072-unix 返回整数", "int", typeName(ts_unix))

var ts_milli = unixMilli()
test("TC072-unixMilli 返回整数", "int", typeName(ts_milli))

var formatted = formatTime(ts_now)
test("TC072-formatTime 返回字符串", "string", typeName(formatted))

