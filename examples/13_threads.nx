// Thread/concurrency example
var counter = 0

func increment(n) {
    let i = 0
    while i < n {
        counter = counter + 1
        i = i + 1
    }
}

// Use "shared" as the LAST argument to share globals
let t1 = thread(increment, 100, "shared")
let t2 = thread(increment, 100, "shared")

// Wait for threads to complete
sleep(0.5)

pln("Counter (should be 200):", counter)
