// Array operations - working around for loop issue
let nums = [1, 2, 3, 4, 5]

// Iterate using indices
pln("Array elements:")
for idx in range(len(nums)) {
    pln("  nums[", idx, "] =", nums[idx])
}

// Manual iteration
pln("Manual iteration:")
let i = 0
while i < len(nums) {
    pln("  nums[", i, "] =", nums[i])
    i = i + 1
}

// Simple operations work
pln("len(nums):", len(nums))
pln("nums[0]:", nums[0])
