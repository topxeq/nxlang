// Test importing a module and checking function equality
import { add, pi } from "./test_module"

// Check that multiple imports get the same function instance
import { add as add2 } from "./test_module"

pln("add == add2:", add == add2)
pln("add(2, 3) =", add(2, 3))
pln("pi =", pi)

// Check that function references work correctly
var f = add
pln("f(5, 7) =", f(5, 7))
pln("f == add:", f == add)
